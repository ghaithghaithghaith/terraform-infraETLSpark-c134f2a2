[
  {
    "service": "glue",
    "resource_name": "aws_glue_job.etl_job",
    "terraform_output_refs": {
      "job_name": "glue_job_name",
      "job_arn": "glue_job_arn",
      "script_bucket_name": "script_bucket_name",
      "script_bucket_arn": "script_bucket_arn",
      "output_bucket_name": "output_bucket_name",
      "output_bucket_arn": "output_bucket_arn",
      "test_script_s3_uri": "test_script_s3_uri",
      "output_data_s3_uri": "output_data_s3_uri",
      "temp_data_s3_uri": "temp_data_s3_uri"
    },
    "action": "replace_artifact",
    "artifact": {
      "type": "script",
      "test_s3_path": "s3://${script_bucket_name}/scripts/etl_test.py",
      "description": "Replace the TEST Glue Python script object with the real Glue ETL script used by the pipeline."
    },
    "notes": "Update the S3 object at the same key used by the Glue job script_location so the job continues to reference the same path after CI/CD uploads the production script."
  }
]
